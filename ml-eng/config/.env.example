# ML/AI-eng env template (copy to your own env file; never commit secrets)

# --- BigQuery (used by RAG BQ retriever + some ML feature pipelines) ---
BQ_PROJECT=opentrace-prod-5ga4
BQ_DATASET_BRONZE=raw_dev

# --- Hugging Face (optional; used for NL2SQL / generation / summarization) ---
HF_API_TOKEN=
# Local SentenceTransformer cache (relative to ml-eng/; auto-resolved by local_env)
HF_HOME=data/local/models/chunking/huggingface
# Must match the model id shown in LM Studio server (e.g. meta-llama-3.1-8b-instruct)
RAG_LLM_MODEL_ID=meta-llama-3.1-8b-instruct
RAG_SUMMARY_MODEL_ID=meta-llama-3.1-8b-instruct
# Local OpenAI-compatible LLM (LM Studio / vLLM). When set, skips HF router (avoids 402 billing).
RAG_LLM_BASE_URL=http://127.0.0.1:1234/v1
# RAG_LLM_API_KEY=
RAG_LLM_TIMEOUT_S=300
RAG_LLM_RERANK=off
RAG_GENERATE_MAX_TOKENS=1024
RAG_GENERATE_TIMEOUT_S=300

# BQ NL-to-SQL: up to 10 queries (one LLM call per vector-matched table hint, sequential by default)
RAG_BQ_MAX_SQL_QUERIES=10
RAG_BQ_NL2SQL_MODE=per_hint
RAG_BQ_NL2SQL_PARALLEL=off
RAG_BQ_SKIP_LIVE_SCHEMA=on
RAG_BQ_ROWS_PER_QUERY=10
RAG_BQ_NL2SQL_MAX_TOKENS=1024
RAG_BQ_NL2SQL_TIMEOUT_S=300
RAG_BQ_HINT_MAX_CHARS=2500

# --- Qdrant Cloud (vector store for RAG) ---
QDRANT_URL=https://...
QDRANT_API_KEY=
QDRANT_COLLECTION=
QDRANT_TIMEOUT_S=30

# --- RAG ingestion from Google Drive (rebuild 4 Qdrant collections) ---
# OAuth client secret json file downloaded from Google Cloud Console (Desktop app).
GDRIVE_OAUTH_CLIENT_SECRET_JSON=
# Token cache (will be created/updated by ingestion CLI)
GDRIVE_TOKEN_PATH=
RAG_INGESTION_STAGING_ROOT=

# Google Drive folder IDs or folder share URLs (share with the logged-in OAuth user)
GDRIVE_FOLDER_RESEARCH_PAPERS_ID=
GDRIVE_FOLDER_OTHER_PAPERS_ID=
GDRIVE_FOLDER_NEWS_ID=
GDRIVE_FOLDER_DATA_DESCRIPTIONS_ID=
GDRIVE_FOLDER_OTA_INSIGHTS_ID=

# Qdrant collection per corpus
QDRANT_COLLECTION_RESEARCH_PAPERS=research_other_papers
QDRANT_COLLECTION_NEWS=news_data
QDRANT_COLLECTION_DATA_DESCRIPTIONS=BQ_table_descriptions
QDRANT_COLLECTION_OTA_INSIGHTS=OTA_insights

# Per-corpus dense vector size (must match embedding model output dim)
RAG_QDRANT_VECTOR_SIZE_NEWS=384
RAG_QDRANT_VECTOR_SIZE_RESEARCH=384
RAG_QDRANT_VECTOR_SIZE_OTA=384
RAG_QDRANT_VECTOR_SIZE_DATA_DESCRIPTIONS=384
# Fallback when a per-corpus var above is unset
RAG_QDRANT_VECTOR_SIZE=384

# Per-corpus embedding models (output dim must match vector size vars above)
RAG_EMBEDDING_MODEL_NEWS=intfloat/multilingual-e5-small
RAG_EMBEDDING_MODEL_RESEARCH=intfloat/multilingual-e5-small
RAG_EMBEDDING_MODEL_OTA=intfloat/multilingual-e5-small
RAG_EMBEDDING_MODEL_DATA_DESCRIPTION=intfloat/multilingual-e5-small
RAG_EMBEDDING_MODEL_ID=intfloat/multilingual-e5-small

# Chunking overrides (defaults in chunking_config.py)
# RAG_CHUNK_TARGET_TOKENS_NEWS=500
# RAG_CHUNK_OVERLAP_PCT_NEWS=0.15
# RAG_CHUNK_TARGET_TOKENS_RESEARCH=700
# RAG_CHUNK_OVERLAP_PCT_RESEARCH=0.10
# RAG_CHUNK_MAX_CHUNKS_RESEARCH=400
# RAG_CHUNK_TARGET_TOKENS_OTA=800
# RAG_CHUNK_TARGET_TOKENS_DATA_DESCRIPTIONS=300

# Per-collection retrieval vector modes (graph + eval use profile defaults)
# news_data: dense + sparse | research: single dense + sparse | OTA: triple + sparse | BQ: table/schema/business
RAG_QDRANT_NEWS_VECTOR_SEARCH_MODE=dense_named
RAG_QDRANT_RESEARCH_VECTOR_SEARCH_MODE=dense_named
RAG_QDRANT_OTA_VECTOR_SEARCH_MODE=ota_triple
RAG_QDRANT_OTA_QUERY_USING=merge
RAG_QDRANT_BQ_VECTOR_SEARCH_MODE=bq_triple
RAG_QDRANT_BQ_QUERY_USING=merge
RAG_QDRANT_VECTOR_SEARCH_MODE=dense_named

# Sparse BM25 + hybrid dense/sparse retrieval (requires fastembed)
RAG_SPARSE_EMBEDDINGS=on
RAG_QDRANT_HYBRID_SEARCH=on
RAG_SPARSE_MODEL=Qdrant/bm25
# Wider prefetch + tight RRF cap improves recall without inflating candidates.
RAG_HYBRID_DENSE_PREFETCH=40
RAG_HYBRID_SPARSE_PREFETCH=40
RAG_HYBRID_FUSION_LIMIT=20

# RAG retrieval / generation (optional)
# RAG_NEWS_DOMAIN_FILTER=on       # strict news domains filter (default off)
# RAG_ALLOW_UNGROUNDED=on         # LLM answers when retrieval is empty (default off)

# Research PDF preprocess (Unstructured + section filtering)
# RAG_USE_UNSTRUCTURED=1
# RAG_UNSTRUCTURED_STRATEGY=fast
# RAG_UNSTRUCTURED_LANGUAGES=eng,fra
# RAG_EXCLUDE_BOILERPLATE_CHUNKS=on
# RAG_RESEARCH_EXCLUDE_ROLES=acknowledgements,references,boilerplate,appendix
# Optional sidecar bibliographic metadata for research PDFs:
#   {pdf}.meta.json  or  research_bibliography.json  (keys: PDF filename or stem)
# Fields: article_title, authors, publication_year, journal, doi, volume, issue, pages

# Web data mining
TAVILY_API_KEY=
OPENAI_API_KEY=

# Auth: use gcloud auth application-default login, or set the path below (relative to ml-eng/).
GOOGLE_APPLICATION_CREDENTIALS=config/keys/opentrace-bq-key.json
