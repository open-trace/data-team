# ML/AI-eng env template (copy to your own env file; never commit secrets)

# --- BigQuery (used by RAG BQ retriever + some ML feature pipelines) ---
BQ_PROJECT=opentrace-prod-5ga4
BQ_DATASET_BRONZE=raw_dev

# --- Hugging Face (optional; used for NL2SQL / generation / summarization) ---
HF_API_TOKEN=
RAG_LLM_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
RAG_SUMMARY_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# --- Qdrant Cloud (vector store for RAG) ---
QDRANT_URL=https://...
QDRANT_API_KEY=
QDRANT_COLLECTION=
QDRANT_TIMEOUT_S=30

# --- RAG ingestion from Google Drive (rebuild 3 Qdrant collections) ---
# OAuth client secret json file downloaded from Google Cloud Console (Desktop app).
GDRIVE_OAUTH_CLIENT_SECRET_JSON=
# Token cache (will be created/updated by ingestion CLI)
GDRIVE_TOKEN_PATH=
RAG_INGESTION_STAGING_ROOT=

# Google Drive folder IDs (share these folders with the logged-in user)
GDRIVE_FOLDER_RESEARCH_PAPERS_ID=
GDRIVE_FOLDER_NEWS_ID=
GDRIVE_FOLDER_DATA_DESCRIPTIONS_ID=

# Qdrant collection per corpus (defaults shown)
QDRANT_COLLECTION_RESEARCH_PAPERS=opentrace_research_papers
QDRANT_COLLECTION_NEWS=opentrace_news
QDRANT_COLLECTION_DATA_DESCRIPTIONS=opentrace_data_descriptions

# Named vectors / embeddings (research + news: sentence + semantic models; data descriptions: sentence only)
# Falls back to RAG_EMBEDDING_MODEL_ID when unset.
RAG_EMBEDDING_MODEL_SENTENCE=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBEDDING_MODEL_SEMANTIC=sentence-transformers/all-mpnet-base-v2
# Retrieval: which named vector(s) to query for dual-vector collections (sentence | semantic | both)
RAG_QDRANT_QUERY_USING=sentence
# Default layout when retrieve() is called without vector_search_mode (legacy | dual | sentence_named)
RAG_QDRANT_VECTOR_SEARCH_MODE=legacy

# Web data mining (Tavily — correct name is TAVILY, not TRAVILY)
TAVILY_API_KEY=
OPENAI_API_KEY=