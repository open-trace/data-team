# BigQuery source (for partition sync)
BQ_PROJECT=opentrace-prod-5ga4
BQ_DATASET=bronze
BQ_TABLE=bronze_events
# Optional: restrict to a partition, e.g. date partition
# BQ_PARTITION_FILTER=date = '2024-01-01'
BQ_PARTITION_LIMIT=10000

# Local DB: PostgreSQL (recommended for team alignment with BigQuery)
# Use a URL. Each developer uses their own DB (see data/local/README.md).
LOCAL_DB_URL=postgresql://postgres:postgres@localhost:5432/datateam_local
LOCAL_TABLE=bronze_events

# Alternative: SQLite (omit LOCAL_DB_URL and set path below)
# LOCAL_DB_PATH=data/local/local.db

# Auth for BigQuery (schema sync, partition sync, dbt):
# - Local dbt: use OAuth (no key). Run: gcloud auth application-default login. Leave GOOGLE_APPLICATION_CREDENTIALS unset.
# - Docker / CI / scripts: set path to a service-account JSON key (relative to repo root when run from repo root).
# GOOGLE_APPLICATION_CREDENTIALS=data/local/keys/opentrace-bq-key.json

# dbt (optional): BigQuery datasets per layer; used by dbt/ when running dbt run --target <layer>
BQ_DATASET_LANDING=landing
BQ_DATASET_BRONZE=bronze
BQ_DATASET_SILVER=silver
BQ_DATASET_GOLD=gold
# Default dbt target when not passing --target (bronze | silver | gold)
# DBT_TARGET=bronze
